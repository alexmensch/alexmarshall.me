{
  "name": "alexmarshall.me",
  "version": "1.0.0",
  "description": "alexmarshall.me counselling website",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "pnpm run format && pnpm run lint && pnpm test && npx @11ty/eleventy",
    "build:cf": "node _cloudflare/r2/generate-assetsignore.js && pnpm run build && cd _cloudflare/r2 && pnpm install && node sync.js",
    "deploy": "pnpm run build:cf && npx wrangler deploy",
    "clean": "rm -rf _site",
    "format": "npx prettier . -wl",
    "11ty:watch": "npx @11ty/eleventy --serve",
    "11ty:debug": "DEBUG=Eleventy* npx @11ty/eleventy --serve",
    "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run lint:md",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:md": "markdownlint-cli2 \"src/**/*.md\"",
    "lint:fix": "pnpm run lint:js -- --fix && pnpm run lint:css -- --fix",
    "prepare": "husky",
    "test": "node --test 'tests/**/*.test.js'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexmensch/alexmarshall.me.git"
  },
  "author": "Alex Marshall",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexmensch/alexmarshall.me/issues"
  },
  "homepage": "https://github.com/alexmensch/alexmarshall.me#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-directory-output": "^1.0.2",
    "dotenv": "^17.3.1",
    "eleventy-plugin-cloudflare-kv": "^1.0.6",
    "eleventy-plugin-purgecss": "^0.6.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-for-inline": "^2.0.1",
    "markdown-it-smartarrows": "^1.0.1",
    "sass": "^1.97.3",
    "slugify": "^1.6.6",
    "utopia-core-scss": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.21.0",
    "opentype.js": "^1.3.4",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "sharp": "0.34.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.34.5"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "sharp"
    ]
  }
}
