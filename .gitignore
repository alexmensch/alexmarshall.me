# OS
.DS_Store

# Editors
.vscode/
.idea/

# Node
node_modules/
.cache
.env
.env.local

# Build output
_site/

# Cloudflare Wrangler
.wrangler

# Claude Code (gitignore the dir but keep skills tracked)
.claude/*
!.claude/skills/
!.claude/skills/**

# Beads / Dolt (added by bd init)
# Note: .beads/ itself is NOT ignored — issues.jsonl is the source of truth
# and propagates via git push.
.dolt/
*.db
.beads-credential-key

# Generated files
_cloudflare/*/worker.js
_cloudflare/*/wrangler.toml
.assetsignore
